# Hatch — environment. Copy to .env and fill from your own secrets. NEVER commit .env.
# --- Splunk Cloud over the 443 web REST proxy (no 8089 / no ACS) ---
SPLUNK_URL=https://prd-p-sh87u.splunkcloud.com
SPLUNK_USER=sc_admin
SPLUNK_PASS=
SPLUNK_LOCALE=en-GB

# --- Gemini on Vertex AI (the agent's reasoning brain) ---
# Path to the service-account JSON key. On Cloud Run, bind the SA instead of shipping the key.
GOOGLE_APPLICATION_CREDENTIALS=../../../_secrets/vertex-sa.json
VERTEX_PROJECT=rapid-agents-5166
VERTEX_LOCATION=global
VERTEX_MODEL=gemini-flash-latest

# --- Server ---
PORT=8787
